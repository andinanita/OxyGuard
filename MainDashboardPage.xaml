<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="pengolahancitra.MainDashboardPage"
             BackgroundColor="#F0FDF4">

    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="16">
        <Frame BackgroundColor="#DCFCE7" CornerRadius="50" WidthRequest="90"
               HeightRequest="90" HorizontalOptions="Center"
               HasShadow="False" Padding="0">
            <Label Text="🫁" FontSize="44" HorizontalOptions="Center"
                   VerticalOptions="Center"/>
        </Frame>
        <Label Text="OxyGuard" FontSize="28" FontAttributes="Bold"
               HorizontalOptions="Center" TextColor="#16A34A"/>
        <ActivityIndicator IsRunning="True" Color="#16A34A"
                           HorizontalOptions="Center"/>
    </VerticalStackLayout>
</ContentPage>