<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="pengolahancitra.RegisterPage"
             BackgroundColor="#F0FDF4">

    <Grid>
        <BoxView Color="#16A34A" VerticalOptions="Start" HeightRequest="220" />

        <ScrollView>
            <VerticalStackLayout Spacing="0">

                <!-- Header -->
                <VerticalStackLayout BackgroundColor="Transparent" Padding="30,50,30,24"
                                     Spacing="6" HorizontalOptions="Center">
                    <Frame BackgroundColor="#DCFCE7" CornerRadius="50" WidthRequest="90"
                           HeightRequest="90" HorizontalOptions="Center"
                           HasShadow="False" Padding="0">
                        <Label Text="📋" FontSize="44" HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Frame>
                    <Label Text="Registrasi Akun" FontSize="26" FontAttributes="Bold"
                           HorizontalOptions="Center" TextColor="#FFFFFF" Margin="0,10,0,0"/>
                    <Label Text="Daftarkan akun baru ke sistem OxyGuard"
                           FontSize="13" HorizontalOptions="Center" TextColor="#BBF7D0"/>
                </VerticalStackLayout>

                <!-- Card Form -->
                <Frame BackgroundColor="#FFFFFF" CornerRadius="24" Padding="28,32"
                       HasShadow="True" Margin="24,0,24,32">
                    <VerticalStackLayout Spacing="16">

                        <!-- Username -->
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Username" FontSize="13" TextColor="#374151"
                                   FontAttributes="Bold"/>
                            <Frame BackgroundColor="#F0FDF4" CornerRadius="10" Padding="0"
                                   HasShadow="False" BorderColor="#BBF7D0">
                                <Entry x:Name="EntryUsername" Placeholder="Buat username baru"
                                       PlaceholderColor="#9CA3AF" BackgroundColor="Transparent"
                                       TextColor="#111827" Margin="8,0"/>
                            </Frame>
                        </VerticalStackLayout>

                        <!-- Password -->
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Password" FontSize="13" TextColor="#374151"
                                   FontAttributes="Bold"/>
                            <Frame BackgroundColor="#F0FDF4" CornerRadius="10" Padding="0"
                                   HasShadow="False" BorderColor="#BBF7D0">
                                <Entry x:Name="EntryPassword" Placeholder="Buat password"
                                       PlaceholderColor="#9CA3AF" IsPassword="True"
                                       BackgroundColor="Transparent"
                                       TextColor="#111827" Margin="8,0"/>
                            </Frame>
                        </VerticalStackLayout>

                        <!-- Role Picker -->
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Hak Akses" FontSize="13" TextColor="#374151"
                                   FontAttributes="Bold"/>
                            <Frame BackgroundColor="#F0FDF4" CornerRadius="10" Padding="0"
                                   HasShadow="False" BorderColor="#BBF7D0">
                                <Picker x:Name="PickerRole" Title="-- Pilih Hak Akses --"
                                        BackgroundColor="Transparent" TextColor="#111827"
                                        TitleColor="#9CA3AF" Margin="8,0"/>
                            </Frame>
                        </VerticalStackLayout>

                        <!-- Status Merokok -->
                        <VerticalStackLayout Spacing="4">
                            <Label Text="🚬 Status Merokok" FontSize="13" TextColor="#374151"
                                   FontAttributes="Bold"/>
                            <Frame BackgroundColor="#F0FDF4" CornerRadius="10" Padding="0"
                                   HasShadow="False" BorderColor="#BBF7D0">
                                <Picker x:Name="PickerMerokok" Title="-- Pilih Status Merokok --"
                                        BackgroundColor="Transparent" TextColor="#111827"
                                        TitleColor="#9CA3AF" Margin="8,0"/>
                            </Frame>
                        </VerticalStackLayout>

                        <!-- Divider -->
                        <BoxView Color="#E5E7EB" HeightRequest="1" Margin="0,4"/>

                        <!-- Foto Wajah -->
                        <Label Text="Foto Wajah untuk Verifikasi"
                               FontSize="13" TextColor="#374151" FontAttributes="Bold"/>
                        <Frame HeightRequest="200" CornerRadius="12" Padding="0"
                               BackgroundColor="#F0FDF4" BorderColor="#BBF7D0"
                               IsClippedToBounds="True">
                            <Grid>
                                <Image x:Name="CameraPreview" Aspect="AspectFill"/>
                                <VerticalStackLayout VerticalOptions="Center"
                                                     HorizontalOptions="Center"
                                                     Spacing="6">
                                    <Label Text="📷" FontSize="36"
                                           HorizontalOptions="Center"/>
                                    <Label Text="Belum ada foto" FontSize="12"
                                           TextColor="#9CA3AF"
                                           HorizontalOptions="Center"/>
                                </VerticalStackLayout>
                            </Grid>
                        </Frame>

                        <Button Text="📷  AMBIL FOTO WAJAH"
                                BackgroundColor="#DCFCE7"
                                TextColor="#15803D"
                                FontAttributes="Bold"
                                FontSize="14"
                                CornerRadius="10"
                                HeightRequest="48"
                                Clicked="OnCaptureFaceClicked"/>

                        <!-- Divider -->
                        <BoxView Color="#E5E7EB" HeightRequest="1" Margin="0,4"/>

                        <!-- Tombol Simpan -->
                        <Button Text="SIMPAN &amp; DAFTARKAN"
                                FontAttributes="Bold"
                                FontSize="15"
                                BackgroundColor="#16A34A"
                                TextColor="White"
                                CornerRadius="12"
                                HeightRequest="52"
                                Clicked="OnRegisterClicked"/>

                        <!-- Kembali -->
                        <Button Text="Kembali ke Login"
                                BackgroundColor="Transparent"
                                TextColor="#16A34A"
                                FontSize="13"
                                Clicked="OnBackToLoginClicked"/>

                    </VerticalStackLayout>
                </Frame>

                <!-- Footer -->
                <Label Text="© 2026 OxyGuard — Sistem Kesehatan Paru"
                       FontSize="11" TextColor="#9CA3AF"
                       HorizontalOptions="Center" Margin="0,0,0,24"/>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>